@startuml
hide circle
hide stereotype
hide members
hide methods
skinparam linetype ortho
skinparam class {
BackgroundColor<<LogicalModel>> #APPLICATION
BackgroundColor<<Profile>> #TECHNOLOGY
}
legend right
| <#APPLICATION>  Logical Model |
| <#TECHNOLOGY>  Profile |
endlegend
class "Alerts" <<LogicalModel>> [[StructureDefinition-AlertsCz.html]]

class "allergyIntolerance-cz-hdr" <<Profile>> [[StructureDefinition-allergyIntolerance-cz-hdr.html]]
"Alerts" <|. "allergyIntolerance-cz-hdr"
class "composition-cz-hdr" <<Profile>> [[StructureDefinition-composition-cz-hdr.html]]
"Alerts" <|. "composition-cz-hdr"
"allergyIntolerance-cz-hdr" -d[hidden]-> "composition-cz-hdr"
class "flag-cz-hdr" <<Profile>> [[StructureDefinition-cz-flag-hdr.html]]
"Alerts" <|. "flag-cz-hdr"
"composition-cz-hdr" -d[hidden]-> "flag-cz-hdr"
@enduml
